# Signals — environment configuration
# Copy this file to `.env` (the start scripts do it for you) and uncomment
# the driver you want. Default is in-memory so the app runs with no config.

# --- Data driver ---------------------------------------------------------
# memory  In-memory mock (default). Resets on page reload.
# local   Persists to browser localStorage. Survives reloads.
# rest    Hits a REST API you provide (see VITE_API_BASE_URL below).
VITE_DATA_DRIVER=memory

# --- REST driver ---------------------------------------------------------
# Required when VITE_DATA_DRIVER=rest. See src/lib/data/rest-source.ts for
# the expected endpoint contract.
# VITE_API_BASE_URL=http://localhost:8787

# --- Dev server ----------------------------------------------------------
# Override the dev server port (default 5173). Honored by start/stop scripts.
# PORT=5173
